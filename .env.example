# Environment Variables Configuration
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://user:password@localhost:5432/checkout_db?schema=public"

# ===========================================
# PAGLOOP PAYMENT GATEWAY
# ===========================================
# API credentials for PagLoop payment gateway
PAGLOOP_API_KEY="your_pagloop_api_key_here"
PAGLOOP_API_SECRET="your_pagloop_api_secret_here"

# Webhook secret - REQUIRED for production
# This is used to validate webhook signatures
PAGLOOP_WEBHOOK_SECRET="your_webhook_secret_here"

# PagLoop API base URL (optional, defaults to production)
PAGLOOP_BASE_URL="https://api.pagloop.com"

# ===========================================
# MERCADO PAGO (Optional - Alternative Gateway)
# ===========================================
MERCADO_PAGO_ACCESS_TOKEN="your_mercado_pago_access_token_here"
MERCADO_PAGO_PUBLIC_KEY="your_mercado_pago_public_key_here"
MERCADO_PAGO_WEBHOOK_SECRET="your_mercado_pago_webhook_secret_here"

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ===========================================
# SECURITY
# ===========================================
# Rate limiting configuration (requests per minute)
RATE_LIMIT_CHECKOUT="10"
RATE_LIMIT_WEBHOOK="100"
RATE_LIMIT_API="30"

# ===========================================
# LOGGING
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL="info"

# ===========================================
# TENANT CONFIGURATION
# ===========================================
# Default tenant ID for single-tenant setups
DEFAULT_TENANT_ID="default"
